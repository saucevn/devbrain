# =====================================================================
# .env  — copy thành .env rồi điền. KHÔNG commit file .env thật.
# =====================================================================

# ----- Postgres (local, trong compose) -------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=doi-thanh-mat-khau-manh
POSTGRES_DB=secondbrain
# DATABASE_URL KHÔNG cần set ở đây — compose tự dựng từ POSTGRES_* ở trên.

# ----- Redis (tên service trong compose) -----------------------------
REDIS_URL=redis://redis:6379

# ----- Secrets -------------------------------------------------------
GITHUB_WEBHOOK_SECRET=xxx
GITHUB_TOKEN=ghp_xxx                  # enrichment API: diff, linked issues
ANTHROPIC_API_KEY=sk-ant-xxx
GEMINI_API_KEY=AIza-xxx                # Google Gemini embeddings (gemini-embedding-001 @ 1536 dims)

# ----- Cloudflare Tunnel ---------------------------------------------
TUNNEL_TOKEN=xxx                      # route → receiver:8000 (+ Access cho dashboard)

# ----- R2 backup (S3-compatible) -------------------------------------
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_BUCKET=second-brain-backups
AWS_ACCESS_KEY_ID=<r2-access-key-id>
AWS_SECRET_ACCESS_KEY=<r2-secret-access-key>
AWS_DEFAULT_REGION=auto
BACKUP_INTERVAL=86400                 # giây giữa 2 lần backup (mặc định 24h)
